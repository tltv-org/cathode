# Cathode — environment configuration
# Copy to .env and set API_KEY before running docker compose up.

# ── Authentication ──

# Management API key — REQUIRED.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=replace-me-with-a-real-secret-key

# ── Server ──

# TZ=UTC
# HOST=0.0.0.0
# PORT=8000

# ── CORS ──

# Comma-separated list of allowed origins. Empty by default (same-origin only).
# CORS_ORIGINS=https://tv.example.com,https://admin.example.com

# ── Logging ──

# LOG_LEVEL=INFO
